        <mxCell id="ll3" style="endArrow=block;html=1;strokeColor=#555;" edge="1" parent="l1l" source="l3" target="l4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="lk" style="endArrow=open;html=1;strokeColor=#38763d;dashed=1;" edge="1" parent="1" source="k" target="l2"><mxGeometry relative="1" as="geometry"/></mxCell>
