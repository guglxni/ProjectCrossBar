<mxfile host="app.diagrams.net" type="device">
  <diagram name="math-curves" id="curves">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Uniform clearing price — demand &amp; supply step curves" style="text;html=1;align=center;fontSize=16;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1"><mxGeometry x="220" y="12" width="660" height="28" as="geometry"/></mxCell>

        <!-- axes -->
        <mxCell id="ax" style="endArrow=classic;html=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="480" as="sourcePoint"/><mxPoint x="980" y="480" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="ay" style="endArrow=classic;html=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="480" as="sourcePoint"/><mxPoint x="120" y="80" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="xl" value="price p (fixed-point)" style="text;html=1;fontSize=11;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="500" y="490" width="140" height="20" as="geometry"/></mxCell>
        <mxCell id="yl" value="executable quantity" style="text;html=1;fontSize=11;fontColor=#555;rotation=-90;" vertex="1" parent="1"><mxGeometry x="50" y="250" width="120" height="20" as="geometry"/></mxCell>

        <!-- demand D(p) steps (non-increasing) -->
        <mxCell id="d1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4a6fa5;strokeColor=#2c4a7c;opacity=80;" vertex="1" parent="1"><mxGeometry x="200" y="140" width="120" height="340" as="geometry"/></mxCell>
        <mxCell id="d2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4a6fa5;strokeColor=#2c4a7c;opacity=80;" vertex="1" parent="1"><mxGeometry x="320" y="220" width="100" height="260" as="geometry"/></mxCell>
        <mxCell id="d3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4a6fa5;strokeColor=#2c4a7c;opacity=80;" vertex="1" parent="1"><mxGeometry x="420" y="300" width="80" height="180" as="geometry"/></mxCell>
        <mxCell id="dl" value="D(p) — buy demand&#10;(price_limit ≥ p)" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#2c4a7c;align=left;" vertex="1" parent="1"><mxGeometry x="200" y="90" width="180" height="36" as="geometry"/></mxCell>

        <!-- supply S(p) steps (non-decreasing) -->
        <mxCell id="s1" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c45c4a;strokeColor=#8b3a2f;opacity=80;" vertex="1" parent="1"><mxGeometry x="500" y="380" width="80" height="100" as="geometry"/></mxCell>
        <mxCell id="s2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c45c4a;strokeColor=#8b3a2f;opacity=80;" vertex="1" parent="1"><mxGeometry x="580" y="300" width="100" height="180" as="geometry"/></mxCell>
        <mxCell id="s3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#c45c4a;strokeColor=#8b3a2f;opacity=80;" vertex="1" parent="1"><mxGeometry x="680" y="200" width="120" height="280" as="geometry"/></mxCell>
        <mxCell id="sl" value="S(p) — sell supply&#10;(price_limit ≤ p)" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#8b3a2f;align=right;" vertex="1" parent="1"><mxGeometry x="720" y="90" width="180" height="36" as="geometry"/></mxCell>

        <!-- p* vertical -->
        <mxCell id="pstar" value="" style="endArrow=none;html=1;strokeColor=#7a3fb5;strokeWidth=3;dashed=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="500" y="480" as="sourcePoint"/><mxPoint x="500" y="100" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="pstarl" value="p* — uniform clearing price&#10;max min(D(p), S(p))" style="text;html=1;fontSize=11;fontStyle=1;fontColor=#7a3fb5;align=center;" vertex="1" parent="1"><mxGeometry x="420" y="500" width="200" height="36" as="geometry"/></mxCell>

        <!-- matched volume bracket -->
        <mxCell id="mv" value="" style="endArrow=none;html=1;strokeColor=#38763d;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="500" y="360" as="sourcePoint"/><mxPoint x="500" y="300" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="mvl" value="matched volume&#10;V = min(D(p*), S(p*))" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#38763d;fontSize=10;" vertex="1" parent="1"><mxGeometry x="520" y="310" width="150" height="44" as="geometry"/></mxCell>

        <!-- legend box -->
        <mxCell id="leg" value="&lt;b&gt;Fill rules at p*&lt;/b&gt;&lt;br&gt;• price_limit &amp;gt; p* (buy) or &amp;lt; p* (sell) → full fill&lt;br&gt;• price_limit = p* → pro-rata at margin (§4)&lt;br&gt;• every fill trades at p*, never at own limit" style="whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#ccc;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="120" y="530" width="420" height="72" as="geometry"/></mxCell>
        <mxCell id="leg2" value="&lt;b&gt;Auction price rule&lt;/b&gt; (Nasdaq/Xetra, arXiv 1407.4512)&lt;br&gt;Among volume-maximizing prices: min |D−S| → market pressure → Pyth ref" style="whiteSpace=wrap;html=1;fillColor=#ede0fb;strokeColor=#7a3fb5;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="560" y="530" width="420" height="72" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
