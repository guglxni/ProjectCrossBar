        <mxCell id="crank" value="crank heartbeat (ScheduleTask) → run_batch every tick" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0fb;strokeColor=#7a3fb5;fontSize=10;" vertex="1" parent="1"><mxGeometry x="655" y="246" width="380" height="34" as="geometry"/></mxCell>
        <mxCell id="engine" value="Clearing engine (pure, deterministic, integer)&#10;curves → uniform p* (Nasdaq/Xetra rule) → pro-rata fills&#10;dual-flow · oracle band · VRF tie-break · CFMM backstop&#10;randomized clearing time (VRF-jittered window close)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcc6f5;strokeColor=#7a3fb5;fontSize=10;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="655" y="292" width="380" height="92" as="geometry"/></mxCell>
        <mxCell id="n1" value="N1: run_batch is a PURE function of the batch set + reference price&#10;(no clock / slot / arrival-order reads → MEV-free within a window)" style="whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#b3261e;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="655" y="396" width="380" height="44" as="geometry"/></mxCell>

