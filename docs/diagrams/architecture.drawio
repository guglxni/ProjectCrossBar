        <mxCell id="cert" value="Correctness oracle: certified parity vs Coq-extracted verified matcher (vendor/dsam UM) — 4006/4006" style="whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#b3261e;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="85" y="470" width="380" height="44" as="geometry"/></mxCell>
        <mxCell id="cert2" value="off-chain harness" style="text;html=1;align=center;fontSize=9;fontColor=#b3261e;" vertex="1" parent="1"><mxGeometry x="85" y="518" width="380" height="16" as="geometry"/></mxCell>

        <!-- Ephemeral plane -->
        <mxCell id="er" value="MagicBlock Ephemeral Rollup  —  ephemeral plane (sub-slot execution)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fd;strokeColor=#7a3fb5;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#4a1a7b;" vertex="1" parent="1"><mxGeometry x="630" y="90" width="430" height="470" as="geometry"/></mxCell>
        <mxCell id="deleg" value="Delegated set (owned by the delegation program):&#10;Market · BatchBook · BatchResult · OraclePrice · OpenOrders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7a3fb5;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="655" y="130" width="380" height="50" as="geometry"/></mxCell>
