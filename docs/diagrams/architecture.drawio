        <mxCell id="book" value="BatchBook PDA&#10;(zero-copy order slab)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="285" y="178" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="result" value="BatchResult PDA&#10;(p*, fills — clearing readout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="85" y="240" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="oracle" value="OraclePrice PDA&#10;(Pyth Lazer reference)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="285" y="240" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="oo" value="OpenOrders PDA (per trader)&#10;claimable / reserved ledger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="85" y="302" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="vault" value="Vault PDAs (base / quote)&#10;SPL token custody" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="285" y="302" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="l1ix" value="L1 instructions:  init_market · deposit / withdraw · settle (Magic Actions) · force_undelegate" style="whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="85" y="372" width="380" height="40" as="geometry"/></mxCell>
        <mxCell id="kora" value="Kora paymaster (gasless submit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#38761d;fontSize=10;" vertex="1" parent="1"><mxGeometry x="85" y="422" width="180" height="34" as="geometry"/></mxCell>
