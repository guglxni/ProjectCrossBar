        <mxCell id="a2l" value="commit / undelegate (ER→L1)" style="text;html=1;fontSize=10;fontColor=#38763d;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="494" y="430" width="132" height="18" as="geometry"/></mxCell>
