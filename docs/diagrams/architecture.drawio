<mxfile host="app.diagrams.net" type="device">
  <diagram name="architecture" id="arch">
    <mxGraphModel dx="1100" dy="760" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1120" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Project CrossBar — Two-Plane Architecture" style="text;html=1;align=center;fontSize=20;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1"><mxGeometry x="300" y="16" width="520" height="30" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="Frequent batch auction: matching + uniform-price clearing run INSIDE a MagicBlock Ephemeral Rollup, settle atomically to Solana L1" style="text;html=1;align=center;fontSize=11;fontColor=#555;" vertex="1" parent="1"><mxGeometry x="180" y="44" width="760" height="20" as="geometry"/></mxCell>

        <!-- Base plane -->
        <mxCell id="base" value="Solana L1  —  base plane (canonical custody &amp; settlement)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#4a6fa5;verticalAlign=top;fontStyle=1;fontSize=13;fontColor=#1a3a6b;" vertex="1" parent="1"><mxGeometry x="60" y="90" width="430" height="470" as="geometry"/></mxCell>
        <mxCell id="prog" value="crossbar program  (Anchor, #[ephemeral])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4a6fa5;fontSize=11;" vertex="1" parent="1"><mxGeometry x="85" y="130" width="380" height="34" as="geometry"/></mxCell>
