<mxfile host="app.diagrams.net" type="device">
  <diagram name="clearing" id="clear">
    <mxGraphModel dx="1200" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="run_batch clearing pipeline (pure, deterministic — N1)" style="text;html=1;align=center;fontSize=16;fontStyle=1;fontColor=#1a1a2e;" vertex="1" parent="1"><mxGeometry x="320" y="14" width="540" height="26" as="geometry"/></mxCell>

        <!-- window gate -->
        <mxCell id="g0" value="window gate&#10;(randomized close,&#10;arXiv 2405.09764)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;" vertex="1" parent="1"><mxGeometry x="40" y="180" width="130" height="100" as="geometry"/></mxCell>
        <mxCell id="g0f" value="FORMING&#10;(accumulate, no clear)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;" vertex="1" parent="1"><mxGeometry x="55" y="300" width="100" height="40" as="geometry"/></mxCell>

        <mxCell id="b1" value="batch SET&#10;(orders in window&#10;+ CFMM ladder)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0fb;strokeColor=#7a3fb5;fontSize=10;" vertex="1" parent="1"><mxGeometry x="210" y="190" width="130" height="80" as="geometry"/></mxCell>
        <mxCell id="b2" value="demand / supply&#10;step curves&#10;D(p), S(p)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0fb;strokeColor=#7a3fb5;fontSize=10;" vertex="1" parent="1"><mxGeometry x="380" y="190" width="130" height="80" as="geometry"/></mxCell>
        <mxCell id="b3" value="uniform p*&#10;max volume → min imbalance&#10;→ pressure → Pyth ref&#10;(Nasdaq/Xetra, arXiv 1407.4512)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcc6f5;strokeColor=#7a3fb5;fontSize=9;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="550" y="180" width="160" height="100" as="geometry"/></mxCell>
        <mxCell id="b4" value="fills at p*&#10;inframarginal full,&#10;marginal pro-rata&#10;(VRF / det. tie-break)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede0fb;strokeColor=#7a3fb5;fontSize=10;" vertex="1" parent="1"><mxGeometry x="750" y="190" width="140" height="80" as="geometry"/></mxCell>
        <mxCell id="b5" value="BatchResult&#10;(p*, volume, fills)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#c9a227;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="930" y="190" width="130" height="80" as="geometry"/></mxCell>

        <!-- oracle band gate above p* -->
        <mxCell id="band" value="oracle band gate&#10;reject p* outside [p_ref±δ],&#10;skip on stale feed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#b3261e;fontSize=9;" vertex="1" parent="1"><mxGeometry x="550" y="70" width="160" height="60" as="geometry"/></mxCell>
        <mxCell id="bandl" style="endArrow=block;html=1;strokeColor=#b3261e;dashed=1;" edge="1" parent="1" source="band" target="b3"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- certified parity callout -->
        <mxCell id="cert" value="CERTIFIED: matched volume + per-order fills are byte-identical to the Coq-extracted verified matcher (vendor/dsam UM) — 4006/4006 batches.  Shuffling the batch is a no-op (order-fairness theorem).  Empty CFMM ⇒ identical to baseline." style="whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#38763d;fontSize=10;align=left;spacingLeft=8;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="210" y="360" width="850" height="50" as="geometry"/></mxCell>

        <mxCell id="e0" value="close" style="endArrow=block;html=1;strokeColor=#555;fontSize=9;" edge="1" parent="1" source="g0" target="b1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e0f" style="endArrow=block;html=1;strokeColor=#999;dashed=1;" edge="1" parent="1" source="g0" target="g0f"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1" style="endArrow=block;html=1;strokeColor=#555;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=block;html=1;strokeColor=#555;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=block;html=1;strokeColor=#555;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=block;html=1;strokeColor=#555;" edge="1" parent="1" source="b4" target="b5"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
